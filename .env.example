# ==========================================
# FixNest Backend Environment Configuration
# ==========================================

# 1. Database Configuration (Supabase PostgreSQL)
# Get this from Supabase Project Settings -> Database -> Connection String (URI)
# Note: Use the connection pooling (transaction mode) string (port 6543) if deploying serverless
DATABASE_URL=postgresql://postgres.your_project_ref:your_password@aws-0-region.pooler.supabase.com:6543/postgres

# 2. Security Config (JWT Tokens Generation)
# Run `openssl rand -hex 32` or enter any secure random hex string
SECRET_KEY=your_super_secret_key_here_generate_with_openssl
ACCESS_TOKEN_EXPIRE_MINUTES=11520
